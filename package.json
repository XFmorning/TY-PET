{
  "name": "ty-ai",
  "version": "1.0.0",
  "description": "TY AI - 桌面AI宠物",
  "main": "main/index.js",
  "scripts": {
    "start": ".\\node_modules\\electron\\dist\\electron.exe .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.ty.ai",
    "productName": "TY AI",
    "files": [
      "main/**/*",
      "renderer/**/*",
      "assets/**/*",
      "animations/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^42.5.1",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "koffi": "^3.1.0"
  }
}
